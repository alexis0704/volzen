{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Venus Server",
            "request": "launch",
            "cwd": "${workspaceFolder}/server",
            "console": "integratedTerminal",
            "preLaunchTask": "Maven: package server",
            "jar": "${workspaceFolder}/server/target/venus-0.0.1-SNAPSHOT.jar",
            "env": {
                "SERVER_PORT": "8080",
                "SPRING_APPLICATION_NAME": "venus",
                "APP_AI_PROVIDER": "ollama",
                "APP_AI_FALLBACK_TO_MOCK_ON_ERROR": "true"
            }
        },
        {
            "type": "java",
            "name": "Venus Server - OpenAI",
            "request": "launch",
            "cwd": "${workspaceFolder}/server",
            "console": "integratedTerminal",
            "preLaunchTask": "Maven: package server",
            "jar": "${workspaceFolder}/server/target/venus-0.0.1-SNAPSHOT.jar",
            "env": {
                "SERVER_PORT": "8080",
                "SPRING_APPLICATION_NAME": "venus",
                "APP_AI_PROVIDER": "openai",
                "APP_AI_OPENAI_BASE_URL": "https://api.openai.com/v1",
                "APP_AI_OPENAI_API_KEY_ENV": "OPENAI_API_KEY",
                "APP_AI_OPENAI_MODEL": "gpt-4.1-mini",
                "APP_AI_FALLBACK_TO_MOCK_ON_ERROR": "true"
            }
        },
        {
            "type": "node-terminal",
            "name": "Venus Frontend",
            "request": "launch",
            "cwd": "${workspaceFolder}/frontend",
            "command": "npm run dev",
            "env": {
                "NEXT_PUBLIC_API_BASE_URL": "http://localhost:8080"
            }
        }
    ],
    "compounds": [
        {
            "name": "Venus Full Stack",
            "configurations": [
                "Venus Server",
                "Venus Frontend"
            ],
            "stopAll": true
        },
        {
            "name": "Venus Full Stack - OpenAI",
            "configurations": [
                "Venus Server - OpenAI",
                "Venus Frontend"
            ],
            "stopAll": true
        }
    ]
}
